---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VitaNexo · Perfil">
  <!-- Topbar -->
  <div class="topbar">
    <div>
      <h1>Perfil de Usuario</h1>
      <div class="sub" id="profile-top-greeting">Buenos días, Shinji Ikari</div>
    </div>
    <div class="topbar-actions">
      <div class="avatar" id="profile-top-avatar" style="width:38px; height:38px; font-size:14px; border-radius:10px;">SI</div>
    </div>
  </div>

  <!-- Content -->
  <div class="content">
    
    <!-- Hazard Warning Bar (Evangelion Style) -->
    <div class="hazard-bar"></div>

    <!-- Profile Card Panel (P3 Reload Status Screen Style) -->
    <div class="panel profile-card-p3">
      <div class="profile-header">
        <div class="avatar-container-p3">
          <div class="avatar" id="profile-avatar">SI</div>
          <div class="avatar-ring-p3"></div>
        </div>
        <div>
          <div id="profile-name" class="p3-name-text">Shinji Ikari</div>
          <div id="profile-email" style="font-size:12px; color:var(--nerv-muted); letter-spacing:0.05em;">shinji@vitanexo.com</div>
          <span class="badge badge-info" id="profile-role-badge" style="margin-top:8px; display:inline-block;">Paciente</span>
        </div>
      </div>
      
      <!-- Patient Specific Clinical Data -->
      <div id="patient-clinical-data">
        <div class="row-pref"><div class="ptitle">TIPO SANGUÍNEO // BLOOD TYPE</div><div class="psub" style="font-weight: 800; color: var(--nerv-magenta);">A+</div></div>
        <div class="row-pref"><div class="ptitle">ALERGENOS // ALLERGENS</div><div class="psub" style="color: var(--nerv-orange); font-weight: bold;">Penicilina</div></div>
        <div class="row-pref"><div class="ptitle">HISTORIAL CRÓNICO // CLINICAL HIST.</div><div class="psub">Asma bronquial, ansiedad leve</div></div>
      </div>

      <!-- Doctor Specific License Data -->
      <div id="doctor-license-data" style="display:none;">
        <div class="row-pref"><div class="ptitle">ESPECIALIDAD // SPECIALTY</div><div class="psub" style="font-weight: 800; color: var(--nerv-magenta);">Pediatría General y Neonatología</div></div>
        <div class="row-pref"><div class="ptitle">CÉDULA PROF. // LICENSE NO.</div><div class="psub" style="font-weight: bold;">CMD-94827-X</div></div>
        <div class="row-pref"><div class="ptitle">DEPARTAMENTO // DEPT</div><div class="psub">División Médica Especializada NERV</div></div>
      </div>
    </div>

    <!-- Preferences Panel - Organized by category -->
    <div class="grid grid-2">
      
      <!-- Interface Settings -->
      <div class="panel">
        <h2 class="p3-section-title"><i class="ti ti-palette"></i> INTERFAZ // SYS.IF</h2>
        
        <div class="row-pref" data-sound="hover">
          <div>
            <div class="ptitle">Modo oscuro · NERV Deep</div>
            <div class="psub">Activa la paleta cyberpunk oscura de Evangelion</div>
          </div>
          <div class="toggle on" id="theme-toggle" data-sound="click"><div class="knob"></div></div>
        </div>

        <div class="row-pref" data-sound="hover">
          <div>
            <div class="ptitle">Efectos de Sonido</div>
            <div class="psub">Habilita chimes y ticks interactivos retro de audio</div>
          </div>
          <div class="toggle on" id="sound-toggle" data-sound="click"><div class="knob"></div></div>
        </div>
      </div>

      <!-- Alerts Settings -->
      <div class="panel">
        <h2 class="p3-section-title"><i class="ti ti-bell-ringing"></i> ALERTAS // SYS.ALERT</h2>
        
        <div class="row-pref" data-sound="hover">
          <div>
            <div class="ptitle">Recordatorios Médicos</div>
            <div class="psub">Notificaciones sobre tus dosis de medicamentos</div>
          </div>
          <div class="toggle on" id="notifications-toggle" data-sound="click"><div class="knob"></div></div>
        </div>

        <div class="row-pref" data-sound="hover">
          <div>
            <div class="ptitle">Alertas de Citas</div>
            <div class="psub">Confirmaciones y reprogramaciones de consultas</div>
          </div>
          <div class="toggle on" id="appointment-alerts-toggle" data-sound="click"><div class="knob"></div></div>
        </div>
      </div>

    </div>

    <!-- General System Config Panel -->
    <div class="panel">
      <h2 class="p3-section-title"><i class="ti ti-settings-automation"></i> SISTEMA GENERAL // SYS.GEN</h2>
      
      <div class="row-pref" data-sound="hover">
        <div>
          <div class="ptitle">Sincronización Inteligente</div>
          <div class="psub">Sincronizar frecuencia cardíaca de pulsera de actividad en segundo plano</div>
        </div>
        <div class="toggle on" id="sync-toggle" data-sound="click"><div class="knob"></div></div>
      </div>
      
      <div class="row-pref" style="border-bottom: none; padding-bottom: 0;">
        <div>
          <div class="ptitle">Memoria Caché</div>
          <div class="psub">Limpiar el historial de datos temporales del simulador local</div>
        </div>
        <button class="btn btn-ghost" id="btn-clear-cache" style="width: auto; margin-top: 0; padding: 6px 12px; font-size: 11px; border: 1px solid var(--nerv-border); border-radius: 4px;" data-sound="click">LIMPIAR CACHÉ</button>
      </div>
    </div>

    <button class="btn btn-logout-p3" id="btn-logout-profile" data-sound="click"><i class="ti ti-logout"></i> C E R R A R &nbsp; S E S I Ó N</button>
  </div>

  <script is:inline>
    function setupProfile() {
      const role = localStorage.getItem('vitanexo_role') || 'patient';
      
      const greeting = document.getElementById('profile-top-greeting');
      const topAvatar = document.getElementById('profile-top-avatar');
      const avatar = document.getElementById('profile-avatar');
      const nameEl = document.getElementById('profile-name');
      const emailEl = document.getElementById('profile-email');
      const badge = document.getElementById('profile-role-badge');
      
      const patientData = document.getElementById('patient-clinical-data');
      const doctorData = document.getElementById('doctor-license-data');

      if (role === 'doctor') {
        if (greeting) greeting.textContent = 'Buenos días, Dra. Yui Ikari';
        if (topAvatar) topAvatar.textContent = 'YI';
        if (avatar) avatar.textContent = 'YI';
        if (nameEl) nameEl.textContent = 'Dra. Yui Ikari';
        if (emailEl) emailEl.textContent = 'yui@vitanexo.com';
        if (badge) {
          badge.textContent = 'Doctor';
          badge.className = 'badge badge-success';
        }
        if (patientData) patientData.style.display = 'none';
        if (doctorData) doctorData.style.display = 'block';
      } else {
        if (greeting) greeting.textContent = 'Buenos días, Shinji Ikari';
        if (topAvatar) topAvatar.textContent = 'SI';
        if (avatar) avatar.textContent = 'SI';
        if (nameEl) nameEl.textContent = 'Shinji Ikari';
        if (emailEl) emailEl.textContent = 'shinji@vitanexo.com';
        if (badge) {
          badge.textContent = 'Paciente';
          badge.className = 'badge badge-info';
        }
        if (patientData) patientData.style.display = 'block';
        if (doctorData) doctorData.style.display = 'none';
      }

      // Handle Theme Toggle
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        const theme = localStorage.getItem('vitanexo_theme') || 'dark';
        if (theme === 'light') {
          themeToggle.classList.remove('on');
        } else {
          themeToggle.classList.add('on');
        }

        themeToggle.addEventListener('click', () => {
          const currentTheme = localStorage.getItem('vitanexo_theme') || 'dark';
          const nextTheme = currentTheme === 'light' ? 'dark' : 'light';
          if (window.applyTheme) {
            window.applyTheme(nextTheme);
          }
        });
      }

      // Handle Sound Toggle
      const soundToggle = document.getElementById('sound-toggle');
      if (soundToggle) {
        const sound = localStorage.getItem('vitanexo_sound') !== 'false';
        if (sound) {
          soundToggle.classList.add('on');
        } else {
          soundToggle.classList.remove('on');
        }

        soundToggle.addEventListener('click', () => {
          const isCurrentlyOn = soundToggle.classList.contains('on');
          if (isCurrentlyOn) {
            soundToggle.classList.remove('on');
            localStorage.setItem('vitanexo_sound', 'false');
          } else {
            soundToggle.classList.add('on');
            localStorage.setItem('vitanexo_sound', 'true');
            // Play a click chime once to confirm
            if (window.playSound) {
              window.playSound('click');
            }
          }
        });
      }

      // Simple toggles visual states
      const setupToggleState = (id, key) => {
        const el = document.getElementById(id);
        if (!el) return;
        const val = localStorage.getItem(key) !== 'false';
        if (val) el.classList.add('on');
        else el.classList.remove('on');

        el.addEventListener('click', () => {
          const isOn = el.classList.contains('on');
          if (isOn) {
            el.classList.remove('on');
            localStorage.setItem(key, 'false');
          } else {
            el.classList.add('on');
            localStorage.setItem(key, 'true');
          }
        });
      };

      setupToggleState('notifications-toggle', 'vitanexo_med_alerts');
      setupToggleState('appointment-alerts-toggle', 'vitanexo_appt_alerts');
      setupToggleState('sync-toggle', 'vitanexo_auto_sync');

      // Clear cache alert
      const clearBtn = document.getElementById('btn-clear-cache');
      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          alert('Caché del sistema de simulación restablecida con éxito.');
        });
      }

      // Logout handler
      const logoutBtn = document.getElementById('btn-logout-profile');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', () => {
          localStorage.removeItem('vitanexo_role');
          window.location.href = '/';
        });
      }
    }

    setupProfile();
    document.addEventListener('astro:after-swap', setupProfile);
  </script>
</Layout>
