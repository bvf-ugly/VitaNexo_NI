---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="VitaNexo · Agenda Doctor">
  <!-- Topbar -->
  <div class="topbar">
    <div>
      <h1>Agenda</h1>
      <div class="sub">Buenos días, Dra. Yui Ikari</div>
    </div>
    <div class="topbar-actions">
      <div class="avatar" style="width:38px; height:38px; font-size:14px; border-radius:10px;">YI</div>
    </div>
  </div>

  <!-- Content -->
  <div class="content">
    <!-- KPIs -->
    <div class="grid grid-3" style="margin-bottom:18px;">
      <div class="kpi-card" style="--accent:var(--nerv-amber)">
        <div class="top">
          <div>
            <div class="label">PENDIENTES</div>
            <div class="value">2</div>
          </div>
          <i class="ti ti-clock"></i>
        </div>
      </div>
      <div class="kpi-card" style="--accent:var(--nerv-green)">
        <div class="top">
          <div>
            <div class="label">CONFIRMADAS</div>
            <div class="value">3</div>
          </div>
          <i class="ti ti-check"></i>
        </div>
      </div>
      <div class="kpi-card" style="--accent:var(--nerv-violet)">
        <div class="top">
          <div>
            <div class="label">TOTAL HOY</div>
            <div class="value">5</div>
          </div>
          <i class="ti ti-calendar"></i>
        </div>
      </div>
    </div>

    <!-- Appointments list panel -->
    <div class="panel">
      <h2><i class="ti ti-list"></i> Hoy · Viernes 12 jun</h2>
      <div class="list-row" data-sound="click">
        <div class="icon-box">09:00</div>
        <div class="info">
          <div class="title">Shinji Ikari</div>
          <div class="meta">Control de asma</div>
        </div>
        <span class="badge badge-success">Confirmada</span>
      </div>
      <div class="list-row" data-sound="click">
        <div class="icon-box">10:30</div>
        <div class="info">
          <div class="title">Hikari Horaki</div>
          <div class="meta">Control preventivo anual</div>
        </div>
        <span class="badge badge-warning">Pendiente</span>
      </div>
      <div class="list-row" data-sound="click">
        <div class="icon-box">12:00</div>
        <div class="info">
          <div class="title">Toji Suzuhara</div>
          <div class="meta">Cefalea tensional</div>
        </div>
        <span class="badge badge-warning">Pendiente</span>
      </div>
    </div>
  </div>
</Layout>
