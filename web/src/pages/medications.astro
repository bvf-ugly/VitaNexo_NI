---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VitaNexo · Medicamentos">
  <!-- Topbar -->
  <div class="topbar">
    <div>
      <h1>Medicamentos</h1>
      <div class="sub">Buenos días, Shinji Ikari</div>
    </div>
    <div class="topbar-actions">
      <div class="avatar" style="width:38px; height:38px; font-size:14px; border-radius:10px;">SI</div>
    </div>
  </div>

  <!-- Content -->
  <div class="content">
    <div class="panel">
      <h2><i class="ti ti-pill"></i> Medicamentos</h2>
      <div class="list-row" data-sound="click">
        <div class="icon-box"><i class="ti ti-pill"></i></div>
        <div class="info">
          <div class="title">Salbutamol inhalador</div>
          <div class="meta">100mcg · PRN · Dra. Yui Ikari</div>
        </div>
        <span class="badge badge-success">Activo</span>
      </div>
      <div class="list-row" data-sound="click">
        <div class="icon-box"><i class="ti ti-pill"></i></div>
        <div class="info">
          <div class="title">Vitamina D3</div>
          <div class="meta">1000 UI · Diario · Dra. Yui Ikari</div>
        </div>
        <span class="badge badge-success">Activo</span>
      </div>
      <div class="list-row" data-sound="click">
        <div class="icon-box"><i class="ti ti-pill"></i></div>
        <div class="info">
          <div class="title">Lorazepam</div>
          <div class="meta">0.5mg · Finalizado 15 mar</div>
        </div>
        <span class="badge badge-warning">Finalizado</span>
      </div>
    </div>

    <div class="panel">
      <h2><i class="ti ti-clock"></i> Próxima dosis</h2>
      <div class="list-row" data-sound="click">
        <div class="icon-box">8:00</div>
        <div class="info">
          <div class="title">Vitamina D3</div>
          <div class="meta">Con el desayuno</div>
        </div>
        <span class="badge badge-info">Hoy</span>
      </div>
    </div>
  </div>
</Layout>
