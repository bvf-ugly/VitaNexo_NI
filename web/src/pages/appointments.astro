---
import Layout from '../layouts/Layout.astro';
---
<Layout title="VitaNexo · Citas">
  <!-- Topbar -->
  <div class="topbar">
    <div>
      <h1>Citas médicas</h1>
      <div class="sub">Buenos días, Shinji Ikari</div>
    </div>
    <div class="topbar-actions">
      <div class="avatar" style="width:38px; height:38px; font-size:14px; border-radius:10px;">SI</div>
    </div>
  </div>

  <!-- Content -->
  <div class="content">
    <div class="grid grid-2">
      <!-- Calendar Panel -->
      <div class="panel">
        <h2><i class="ti ti-calendar"></i> Junio 2026</h2>
        <div class="calendar">
          <div class="dow">L</div><div class="dow">M</div><div class="dow">X</div><div class="dow">J</div><div class="dow">V</div><div class="dow">S</div><div class="dow">D</div>
          
          <div class="day" data-sound="hover">8</div>
          <div class="day" data-sound="hover">9</div>
          <div class="day" data-sound="hover">10</div>
          <div class="day active" data-sound="hover">11<div class="dot"></div></div>
          <div class="day" data-sound="hover">12<div class="dot"></div></div>
          <div class="day" data-sound="hover">13</div>
          <div class="day" data-sound="hover">14</div>
          
          <div class="day" data-sound="hover">15</div>
          <div class="day" data-sound="hover">16</div>
          <div class="day" data-sound="hover">17</div>
          <div class="day" data-sound="hover">18</div>
          <div class="day" data-sound="hover">19</div>
          <div class="day" data-sound="hover">20</div>
          <div class="day" data-sound="hover">21</div>
        </div>
      </div>

      <!-- Upcoming Appointments -->
      <div class="panel">
        <h2><i class="ti ti-list"></i> Próximas citas</h2>
        <div class="list-row" data-sound="click">
          <div class="icon-box"><i class="ti ti-stethoscope"></i></div>
          <div class="info">
            <div class="title">Dra. Yui Ikari</div>
            <div class="meta">Pediatría · Vie 12 jun · 09:00</div>
          </div>
          <span class="badge badge-success">Confirmada</span>
        </div>
        <div class="list-row" data-sound="click">
          <div class="icon-box"><i class="ti ti-stethoscope"></i></div>
          <div class="info">
            <div class="title">Dr. Gendou Ikari</div>
            <div class="meta">Neurología · Mar 23 jun · 11:30</div>
          </div>
          <span class="badge badge-warning">Pendiente</span>
        </div>
        <button class="btn btn-primary" style="margin-top:14px;" data-sound="click">+ SOLICITAR NUEVA CITA</button>
      </div>
    </div>
  </div>
</Layout>
